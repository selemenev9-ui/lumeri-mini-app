.perspectiveWrap {
  width: 100%;
  height: 100%;
  perspective: 1000px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card {
  position: relative;
  width: min(100%, 340px);
  height: 100%;
  border-radius: 20px;
  transform-style: preserve-3d;
  overflow: hidden;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.62) 0%, rgba(245, 240, 232, 0.72) 55%, rgba(255, 255, 255, 0.4) 100%);
  border: 1px solid rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 16px 34px rgba(0, 0, 0, 0.16);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 18px;
}

.light {
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.62) 0%, rgba(245, 240, 232, 0.72) 55%, rgba(255, 255, 255, 0.4) 100%);
  border: 1px solid rgba(255, 255, 255, 0.4);
  color: var(--ink);
}

.dark {
  background:
    linear-gradient(145deg, rgba(30, 30, 30, 0.6) 0%, rgba(10, 10, 10, 0.8) 100%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #f4e8cf;
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.52), transparent 58%);
  pointer-events: none;
}

.dark::before {
  background: radial-gradient(circle at 18% 18%, rgba(220, 220, 220, 0.2), transparent 60%);
}

.levitate {
  position: relative;
  z-index: 3;
  transform: translateZ(30px);
}

.brand {
  font-size: 12px;
  letter-spacing: 0.18em;
  opacity: 0.78;
}

.name {
  align-self: center;
  margin-top: -8px;
  font-family: var(--font-display);
  font-size: 42px;
  line-height: 1;
  text-align: center;
}

.bottomRow {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.status {
  font-size: 11px;
  letter-spacing: 0.16em;
  opacity: 0.72;
}

.vkId {
  font-size: 12px;
  letter-spacing: 0.05em;
  opacity: 0.6;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace;
}

.light .brand,
.light .name,
.light .status,
.light .vkId {
  color: var(--ink);
}

.dark .brand,
.dark .name,
.dark .status,
.dark .vkId {
  color: #f4e8cf;
}

.glare {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  z-index: 2;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.rim {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  z-index: 1;
  transition: box-shadow 0.18s ease-out;
}

.grain {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  z-index: 1;
  opacity: 0.06;
  background-image:
    radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px),
    radial-gradient(circle at 80% 30%, rgba(255, 255, 255, 0.07) 0 1px, transparent 1px),
    radial-gradient(circle at 40% 70%, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px);
  background-size: 9px 9px, 11px 11px, 13px 13px;
  mix-blend-mode: soft-light;
}

.sweep {
  position: absolute;
  inset: -20% -80%;
  border-radius: inherit;
  pointer-events: none;
  z-index: 2;
  background: linear-gradient(110deg, rgba(255, 255, 255, 0) 38%, rgba(255, 255, 255, 0.22) 50%, rgba(255, 255, 255, 0) 62%);
  transform: translateX(-120%);
  animation: sweep-in 1.15s ease-out 0.2s both;
}

.dark .grain {
  opacity: 0.08;
}

.dark .sweep {
