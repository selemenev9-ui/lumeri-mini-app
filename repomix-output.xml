const SEASON_OVERRIDES = {
  b15: ['summer'],
  b19: ['winter'],
  b20: ['summer'],
  l5: ['summer'],
  s10: ['winter'],
  s14: ['summer'],
  s15: ['winter'],
  s20: ['spring'],
  h9: ['winter'],
  h13: ['summer'],
  p5: ['winter'],
  p7: ['summer'],
  e3: ['summer'],
  e10: ['summer'],
  n8: ['winter'],
  m7: ['summer']
};

export const CARE_DATA = BASE_CARE_DATA.map((tip) => ({
  ...tip,
  seasons: SEASON_OVERRIDES[tip.id] ?? ['all']
}));

export function getCurrentSeason() {
  const month = new Date().getMonth();
  if (month >= 2 && month <= 4) return 'spring';
  if (month >= 5 && month <= 7) return 'summer';
  if (month >= 8 && month <= 10) return 'autumn';
  return 'winter';
}

export function getDailyTips(count = 3, seenIds = []) {
  const today = new Date();
  const seed = today.getFullYear() * 10000 + (today.getMonth() + 1) * 100 + today.getDate();
  const seededRandom = (s) => {
    const x = Math.sin(s) * 10000;
    return x - Math.floor(x);
  };

  const safeSeenIds = Array.isArray(seenIds) ? seenIds : [];
  const currentSeason = getCurrentSeason();
  const seasonPool = CARE_DATA.filter(
    (tip) => tip.seasons.includes('all') || tip.seasons.includes(currentSeason)
  );
  let available = seasonPool.filter((tip) => !safeSeenIds.includes(tip.id));

  if (available.length < count) {
    const recentSeenIds = safeSeenIds.slice(-5);
    const allSeasonPool = CARE_DATA.filter(
      (tip) => tip.seasons.includes('all') && !recentSeenIds.includes(tip.id)
    );

    const merged = [...available];
    allSeasonPool.forEach((tip) => {
      if (!merged.some((item) => item.id === tip.id)) {
        merged.push(tip);
      }
    });
    available = merged;
  }

  const safeCount = Math.max(0, Math.min(count, available.length));
  const selected = [];
  let currentSeed = seed;

  for (let i = 0; i < safeCount; i += 1) {
    const randomIndex = Math.floor(seededRandom(currentSeed) * available.length);
    selected.push(available[randomIndex]);
    available.splice(randomIndex, 1);
    currentSeed += 1;
  }

  return {
    tips: selected,
    newSeenIds: [...new Set([...safeSeenIds, ...selected.map((tip) => tip.id)])]
  };
}
