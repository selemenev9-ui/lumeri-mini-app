<file path="src/screens/BookingScreen.module.css">
.booking {
  position: relative;
  min-height: 100dvh;
  padding: calc(var(--safe-top) + 24px) 20px calc(var(--safe-bottom) + var(--tabbar-space));
  overflow: hidden;
}

.ambientGlow {
  position: absolute;
  width: 200%;
  height: 200%;
  top: -50%;
  left: -50%;
  filter: blur(80px);
  pointer-events: none;
  z-index: 0;
}

.contentLayer {
  position: relative;
  z-index: 1;
}

.header {
  position: relative;
  z-index: 2;
  margin-bottom: 28px;
}

.kicker {
  font-size: 11px;
  letter-spacing: 0.3em;
  color: var(--ink-60);
  text-transform: uppercase;
}

.title {
  font-family: var(--font-display);
  font-size: 34px;
  text-transform: lowercase;
  margin: 4px 0 0;
}

.tabsContainer {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 0 20px 16px;
  margin: 0 -20px;
  scrollbar-width: none;
}

.tabsContainer::-webkit-scrollbar {
  display: none;
}

.tab {
  padding: 8px 16px;
  border-radius: 20px;
  border: 1px solid rgba(0, 0, 0, 0.1);
  background: transparent;
  color: var(--ink);
  white-space: nowrap;
  transition: 0.3s;
  font-family: var(--font-body);
}

.activeTab {
  background: var(--ink);
  color: var(--cream);
  border-color: var(--ink);
}

.step {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.sectionTitle {
  font-family: var(--font-display);
  font-size: 28px;
  font-style: italic;
  margin-bottom: 4px;
}

.cardStack {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.serviceCard {
  width: 100%;
  display: flex;
  flex-direction: column;
  border: 1px solid transparent;
  padding: 16px;
  text-align: left;
  cursor: pointer;
  transition: border-color 0.28s var(--smooth), background 0.28s var(--smooth), transform 0.22s var(--smooth);
}

.serviceCard:focus-visible {
  outline: 2px solid rgba(28, 28, 30, 0.45);
  outline-offset: 2px;
}

.cardContent {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 10px;
}

.serviceMetadata {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
  padding-top: 10px;
}

.serviceTitle {
  font-size: 15px;
  line-height: 1.25;
  font-weight: 500;
  color: var(--ink);
  margin: 0;
}

.activeCard {
  border: 1px solid var(--ink);
  background: rgba(255, 255, 255, 0.65);
  transform: scale(0.98);
}

.serviceDuration {
  font-size: 13px;
  color: rgba(0, 0, 0, 0.4);
}

.servicePrice {
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
}

.inlineBookButton {
  width: 100%;
  padding: 14px 0;
  background: var(--ink);
  color: var(--cream);
  border-radius: 12px;
  font-weight: 600;
  font-family: var(--font-body);
  border: none;
}

.selectedBar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.4);
  border: 0.5px solid rgba(255, 255, 255, 0.85);
  border-radius: 16px;
  margin-bottom: 16px;
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
}

.selectedTitle {
  font-size: 14px;
  font-weight: 500;
  color: #1c1c1e;
}

.selectedPrice {
  font-size: 12px;
  color: rgba(28, 28, 30, 0.5);
}

.dateStrip {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 8px;
  scroll-snap-type: x mandatory;
}

.dateChip {
  min-width: 100px;
  padding: 14px;
  border-radius: 999px;
  border: 1px solid rgba(0, 0, 0, 0.08);
  background: rgba(255, 255, 255, 0.65);
  scroll-snap-align: start;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.dateActive {
  background: var(--ink);
  color: #fff;
}

.dateNum {
  font-size: 16px;
  font-weight: 500;
}

.dateWeek {
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.slot {
  padding: 18px 0;
  border-radius: 18px;
  text-align: center;
  background: rgba(255, 255, 255, 0.65);
  border: 1px solid rgba(0, 0, 0, 0.06);
  font-weight: 500;
  transition: transform 0.25s var(--spring), background 0.3s;
}

.slot:active {
  transform: scale(0.94);
}

.slotBusy {
  opacity: 0.4;
  text-decoration: line-through;
}

.slotActive {
  background: var(--ink);
  color: white;
}

.confirm {
  position: fixed;
  inset: 0;
  z-index: 100;
  padding: 60px 30px 40px;
  background: #111820;
  color: white;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20px;
}

.confirmLogo {
  width: 120px;
  height: auto;
}

.confirmRing {
  position: relative;
  width: 120px;
  height: 120px;
}

.confirmRingTrack,
.confirmRingSpinner {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.confirmRingSpinner {
  border-top-color: rgba(255, 255, 255, 0.7);
  border-left-color: transparent;
  animation: spin 8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.confirmTitle {
  font-family: var(--font-display);
  font-size: 34px;
  margin: 0;
}

.confirmDetails {
  color: rgba(255, 255, 255, 0.7);
}

.confirmService {
  font-size: 16px;
  font-weight: 500;
  margin-bottom: 4px;
}

.confirmMeta {
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  display: flex;
  gap: 8px;
  justify-content: center;
}

.confirmActions {
  margin-top: 32px;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.confirmOutline {
  border-radius: var(--radius-pill);
  padding: 14px 28px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.7);
  background: transparent;
}

.selectedBar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.4);
  border: 0.5px solid rgba(255, 255, 255, 0.85);
  border-radius: 16px;
  margin-bottom: 16px;
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
}
</file>

<file path="src/screens/HomeScreen.module.css">
.home {
  position: relative;
  width: 100%;
  min-height: 100dvh;
  color: var(--cream);
}

.heroPhoto {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  overflow: hidden;
  z-index: 0;
}

.heroImg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  animation: kenburns 14s ease-in-out infinite alternate;
}

@keyframes kenburns {
  from {
    transform: scale(1) translate(0, 0);
  }
  to {
    transform: scale(1.06) translate(-1%, 2%);
  }
}

.heroFade {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 50%;
  z-index: 1;
  background: linear-gradient(
    0deg,
    #F5F0E8 0%,
    rgba(245,240,232,0.98) 25%,
    rgba(245,240,232,0.7) 45%,
    transparent 100%
  );
}

.logoCenter {
  position: absolute;
  top: 8%;
  left: 0;
  right: 0;
  text-align: center;
  font-family: var(--font-display);
  font-size: 30px;
  letter-spacing: 0.26em;
  color: rgba(255, 255, 255, 0.92);
  z-index: 2;
  white-space: nowrap;
}

.content {
  position: absolute;
  left: 18px;
  right: 18px;
  bottom: calc(80px + var(--safe-bottom));
  display: flex;
  flex-direction: column;
  gap: 10px;
  z-index: 3;
  color: var(--ink);
}

.greetingRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.greeting {
  font-family: var(--font-display);
  font-size: 12px;
  font-style: italic;
  letter-spacing: 0.05em;
  margin: 0;
  color: var(--ink);
  flex: 1;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  padding-left: 18px;
}

.datePill {
  position: absolute;
  top: 16%;
  right: 18px;
  z-index: 2;
  padding: 6px 12px;
  border-radius: 20px;
  background: rgba(245, 240, 232, 0.18);
  color: rgba(255, 255, 255, 0.75);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 0.5px solid rgba(255, 255, 255, 0.3);
}

.slotCard {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 12px 16px;
  border-radius: 20px;
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.18);
  border: 0.5px solid rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.3) inset;
}

.slotCard::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(255, 210, 183, 0.35), transparent 60%);
  opacity: 0;
  transform: scale(0.5);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.slotCard:active::after {
  opacity: 1;
  transform: scale(1.4);
}

.slotLabel {
  font-size: 8px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.55);
}

.slotTime {
  font-family: var(--font-display);
  font-size: 22px;
  margin: 4px 0;
  color: rgba(255, 255, 255, 0.85);
}

.slotMeta {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.55);
}

.slotCard :global(.btn-ink) {
  background: rgba(255, 255, 255, 0.9);
  color: #1C1C1E;
  padding: 8px 16px;
  font-size: 13px;
}

.categories {
  display: flex;
  gap: 8px;
}

.categoryChip {
  flex: 1;
  border-radius: 24px;
  padding: 10px 16px;
  background: rgba(255, 255, 255, 0.4);
  border: 0.5px solid rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(30px);
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-60);
  display: inline-flex;
  justify-content: center;
  align-items: center;
  transition: background 0.25s var(--smooth), color 0.25s var(--smooth);
}

.categoryActive {
  background: rgba(255, 255, 255, 0.85);
  color: var(--ink);
}

.countdownWrap {
  box-shadow: 0 -8px 32px rgba(245, 240, 232, 0.8);
  border-radius: 22px;
}

.countdownCard {
  background: rgba(28, 28, 30, 0.82);
  border-radius: 22px;
  padding: 20px;
  color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 -20px 40px rgba(245, 240, 232, 0.6);
}

.countLabel {
  font-size: 12px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  opacity: 0.7;
}

.countValue {
  font-family: var(--font-display);
  font-size: 22px;
  margin: 12px 0;
}
</file>

